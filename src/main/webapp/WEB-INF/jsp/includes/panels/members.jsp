<section class="tab-panel" id="panel-members" role="tabpanel">
    <div class="panel-header">
        <div>
            <h2>Group Members</h2>
            <p class="subtitle">People in this expense group</p>
        </div>
        <button class="btn btn-primary" id="btnAddMember" type="button">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            Add Member
        </button>
    </div>
    <div class="member-grid" id="memberGrid">
        <div class="empty-state">
            <div class="empty-icon">
                <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>
            </div>
            <p>No members in this group</p>
        </div>
    </div>
</section>
